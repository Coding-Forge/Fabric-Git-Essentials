{
  "rules": [
    {
      "id": "REDUCE_VISUALS_ON_PAGE",
      "name": "Reduce the number of visible visuals on the page",
      "description": "Limit visible visuals per page to keep reports readable and responsive.",
      "logType": "warning",
      "itemType": "Report",
      "part": "Pages",
      "disabled": false,
      "test": [
        {
          "<=": [
            {
              "count": [
                {
                  "filter": [
                    {
                      "part": "Visuals"
                    },
                    {
                      "and": [
                        {
                          "!": [
                            {
                              "var": "isHidden"
                            }
                          ]
                        },
                        {
                          "!": [
                            {
                              "in": [
                                {
                                  "var": "visual.visualType"
                                },
                                [
                                  "shape",
                                  "slicer",
                                  "actionButton",
                                  "textbox"
                                ]
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "var": "paramMaxVisualsPerPage"
            }
          ]
        },
        {
          "paramMaxVisualsPerPage": 12
        },
        true
      ]
    },
    {
      "id": "REDUCE_OBJECTS_WITHIN_VISUALS",
      "name": "Reduce the number of objects within visuals",
      "description": "Keep visuals focused by limiting the number of projected fields.",
      "logType": "warning",
      "itemType": "Report",
      "part": "Pages",
      "disabled": false,
      "test": [
        {
          "map": [
            {
              "filter": [
                {
                  "part": "Visuals"
                },
                {
                  ">": [
                    {
                      "count": [
                        {
                          "path": "$..projections[*]"
                        }
                      ]
                    },
                    5
                  ]
                }
              ]
            },
            {
              "var": "name"
            }
          ]
        },
        {},
        []
      ]
    },
    {
      "id": "REDUCE_ADVANCED_FILTERS",
      "name": "Reduce usage of Advanced filtering visuals by page",
      "description": "Keep advanced filters intentional and limited.",
      "logType": "warning",
      "itemType": "Report",
      "part": "Pages",
      "disabled": true,
      "test": [
        {
          "<=": [
            {
              "count": [
                {
                  "filter": [
                    {
                      "part": "Visuals"
                    },
                    {
                      "some": [
                        {
                          "var": "filterConfig.filters"
                        },
                        {
                          "==": [
                            {
                              "var": "type"
                            },
                            "Advanced"
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "var": "paramMaxAdvancedFilteringPerPage"
            }
          ]
        },
        {
          "paramMaxAdvancedFilteringPerPage": 2
        },
        true
      ]
    },
    {
      "id": "REDUCE_PAGES",
      "name": "Reduce number of pages per report",
      "description": "Keep reports concise enough for users to navigate quickly.",
      "logType": "warning",
      "itemType": "Report",
      "disabled": false,
      "test": [
        {
          "<=": [
            {
              "count": [
                {
                  "part": "Pages"
                }
              ]
            },
            6
          ]
        },
        {},
        true
      ]
    },
    {
      "id": "ENSURE_THEME_COLOURS",
      "name": "Ensure charts use theme colours",
      "description": "Custom hard-coded colours should not override the team theme.",
      "logType": "error",
      "itemType": "Report",
      "part": "Pages",
      "disabled": false,
      "test": [
        {
          "map": [
            {
              "filter": [
                {
                  "part": "Visuals"
                },
                {
                  "and": [
                    {
                      "!": [
                        {
                          "in": [
                            {
                              "var": "visual.visualType"
                            },
                            [
                              "textbox"
                            ]
                          ]
                        }
                      ]
                    },
                    {
                      "strcontains": [
                        {
                          "tostring": [
                            {
                              "var": ""
                            }
                          ]
                        },
                        "#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})"
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "var": "name"
            }
          ]
        },
        {},
        []
      ]
    },
    {
      "id": "ENSURE_PAGES_DO_NOT_SCROLL_VERTICALLY",
      "name": "Ensure pages do not scroll vertically",
      "description": "Visible pages should fit standard canvas height.",
      "logType": "error",
      "itemType": "Report",
      "disabled": false,
      "test": [
        {
          "map": [
            {
              "filter": [
                {
                  "part": "Pages"
                },
                {
                  "and": [
                    {
                      ">": [
                        {
                          "var": "height"
                        },
                        720
                      ]
                    },
                    {
                      "!=": [
                        {
                          "var": "visibility"
                        },
                        "HiddenInViewMode"
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "var": "displayName"
            }
          ]
        },
        {},
        []
      ]
    },
    {
      "id": "ACTIVE_PAGE",
      "name": "Active page",
      "description": "Ensure the report opens on its first page.",
      "logType": "warning",
      "itemType": "Report",
      "part": "PagesHeader",
      "disabled": false,
      "test": [
        {
          "==": [
            {
              "var": "activePageName"
            },
            {
              "var": "pageOrder.0"
            }
          ]
        },
        {},
        true
      ]
    },
    {
      "id": "SHOW_AXES_TITLES",
      "name": "Show visual axes titles",
      "description": "Core comparison charts should expose axis titles.",
      "logType": "warning",
      "itemType": "Report",
      "part": "Pages",
      "disabled": false,
      "test": [
        {
          "map": [
            {
              "filter": [
                {
                  "part": "Visuals"
                },
                {
                  "and": [
                    {
                      "in": [
                        {
                          "var": "visual.visualType"
                        },
                        [
                          "lineChart",
                          "barChart",
                          "columnChart",
                          "clusteredBarChart",
                          "stackedBarChart",
                          "clusteredColumnChart"
                        ]
                      ]
                    },
                    {
                      "or": [
                        {
                          "==": [
                            {
                              "var": "visual.objects.categoryAxis.0.properties.showAxisTitle.expr.Literal.Value"
                            },
                            "false"
                          ]
                        },
                        {
                          "==": [
                            {
                              "var": "visual.objects.valueAxis.0.properties.showAxisTitle.expr.Literal.Value"
                            },
                            "false"
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "var": "name"
            }
          ]
        },
        {},
        []
      ]
    },
    {
      "id": "GIVE_VISIBLE_PAGES_MEANINGFUL_NAMES",
      "name": "Give visible pages meaningful names",
      "description": "Avoid default page names like Page 1 or Page 2 in published reports.",
      "logType": "warning",
      "itemType": "Report",
      "disabled": false,
      "test": [
        {
          "map": [
            {
              "filter": [
                {
                  "part": "Pages"
                },
                {
                  "and": [
                    {
                      "strcontains": [
                        {
                          "var": "displayName"
                        },
                        "^Page [1-9]+$"
                      ]
                    },
                    {
                      "!=": [
                        {
                          "var": "visibility"
                        },
                        "HiddenInViewMode"
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "var": "displayName"
            }
          ]
        },
        {},
        []
      ]
    },
    {
      "id": "CHECK_FOR_LOCAL_MEASURES",
      "name": "Check for locally defined measures",
      "description": "Report-level measures should live in the semantic model unless there is a deliberate exception.",
      "logType": "warning",
      "itemType": "Report",
      "part": "ReportExtensions",
      "disabled": true,
      "test": [
        {
          "filter": [
            {
              "var": "entities"
            },
            {
              ">": [
                {
                  "count": [
                    {
                      "var": "measures"
                    }
                  ]
                },
                0
              ]
            }
          ]
        },
        {
          "entities": "/entities"
        },
        []
      ]
    }
  ]
}
