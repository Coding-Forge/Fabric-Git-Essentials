model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup 'Transform File from Sample file (3)'

	annotation PBI_QueryGroupOrder = 0

queryGroup 'Transform File from Sample file (3)\Helper Queries'

	annotation PBI_QueryGroupOrder = 0

queryGroup 'Transform File from International Sales'

	annotation PBI_QueryGroupOrder = 2

queryGroup 'Transform File from International Sales\Helper Queries'

	annotation PBI_QueryGroupOrder = 0

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Sales","Product","Geography","Manufacturer","International Sales","Sample File","Parameter1","Transform Sample File","Transform File","Sample File (2)","Parameter2","Transform Sample File (2)","Transform File (2)"]

annotation PBI_ProTooling = ["DevMode"]

ref table Sales
ref table Product
ref table Geography
ref table Manufacturer
ref table Date

ref cultureInfo en-US

